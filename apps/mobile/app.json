{
  "expo": {
    "name": "Movia",
    "slug": "movia",
    "scheme": "movia",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "android": {
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.anonymous.movia"
    },
    "ios": {
      "supportsTablet": true
    },
    "version": "1.0.0"
  }
}