{
  "expo": {
    "name": "Movia",
    "slug": "movia",
    "scheme": "movia",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "android": {
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "ios": {
      "supportsTablet": true
    }
  }
}