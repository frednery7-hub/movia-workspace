{
  "ts-node": {
    "compilerOptions": {
      "allowImportingTsExtensions": true,
      "noEmit": true
    }
  },
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["jest", "node"],
    "paths": {
      "@movia/shared-data/*": ["../../packages/shared-data/src/*"],
      "@movia/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@movia/route-engine": ["../../packages/route-engine/src/index.ts"]
    }
  },
  "include": ["src/**/*", "prisma/seed.ts", "test/**/*"]
}