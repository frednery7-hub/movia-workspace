# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=movia_db

# ─── Cache (Redis) ────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Auth ─────────────────────────────────────────────────────
# Minimo 32 caracteres — gerar com: openssl rand -hex 32
JWT_SECRET="your_secret_minimum_32_characters_here"

# ─── Allowed Origins (CORS) ───────────────────────────────────
# Separados por virgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_ORIGIN=http://localhost:8081

# ─── Privacy / Compliance ─────────────────────────────────────
PRIVACY_REGION=CL
PRIVACY_RESPONSE_SLA_DAYS=30

# ─── Integracoes ──────────────────────────────────────────────
MAPBOX_PUBLIC_TOKEN=
SENTRY_DSN=
# Obrigatorio em producao — protege GET /metrics (min 16 chars)
METRICS_TOKEN="your_metrics_token_here"

# ─── Address / Places Search (Backend only) ───────────────────
ADDRESS_SEARCH_ENABLED=false
GOOGLE_GEOCODING_API_KEY="your_google_geocoding_api_key_here"
ADDRESS_SEARCH_CACHE_TTL_SECONDS=604800
ADDRESS_SEARCH_MAX_RESULTS=5
PLACES_SEARCH_ENABLED=false
GOOGLE_PLACES_API_KEY="your_google_places_api_key_here"
PLACES_AUTOCOMPLETE_CACHE_TTL_SECONDS=300
PLACES_DETAILS_CACHE_TTL_SECONDS=604800
PLACES_MAX_RESULTS=5
PLACES_COUNTRY_CODE=CL
PLACES_LOCATION_BIAS_LAT=-33.4489
PLACES_LOCATION_BIAS_LNG=-70.6693
PLACES_LOCATION_BIAS_RADIUS_METERS=35000
