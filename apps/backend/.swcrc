{
  "jsc": {
    "baseUrl": "/Users/fredleal/Desktop/movia-workspace/apps/backend",
    "paths": {
      "@movia/shared-data/*": ["../../packages/shared-data/src/*"],
      "@movia/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@movia/route-engine": ["../../packages/route-engine/src/index.ts"]
    },
    "parser": {
      "syntax": "typescript",
      "decorators": true
    },
    "transform": {
