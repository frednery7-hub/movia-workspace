{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json",
        "isolatedModules": true
      }
    ]
  },
  "clearMocks": true,
  "restoreMocks": true,
  "maxWorkers": 1,
  "testTimeout": 30000
}