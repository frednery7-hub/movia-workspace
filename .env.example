# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/movia_db?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=movia_db

# ─── Cache (Redis) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your_secret_minimum_32_characters_here

# ─── Allowed Origins (CORS) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_ORIGIN=http://localhost:8081

# ─── Privacy / Compliance ─────────────────────────────────────
PRIVACY_REGION=CL
PRIVACY_RESPONSE_SLA_DAYS=30

# ─── Integracoes ──────────────────────────────────────────────
MAPBOX_PUBLIC_TOKEN=
SENTRY_DSN=

# ─── Address Search (Backend only) ────────────────────────────
ADDRESS_SEARCH_ENABLED=false
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here
ADDRESS_SEARCH_CACHE_TTL_SECONDS=604800
ADDRESS_SEARCH_MAX_RESULTS=5
